{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main", "backup-selector"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-set-webview-focus",
    "dialog:default",
    "fs:default",
    "process:default",
    "store:default",
    "updater:default",
    "opener:default",
    "os:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.papermc.io/**" },
        { "url": "https://piston-meta.mojang.com/**" },
        { "url": "https://launchermeta.mojang.com/**" },
        { "url": "https://meta.fabricmc.net/**" },
        { "url": "https://api.modrinth.com/**" },
        { "url": "https://cdn.modrinth.com/**" },
        { "url": "https://hangar.papermc.io/**" },
        { "url": "https://api.spiget.org/**" },
        { "url": "https://www.spigotmc.org/**" },
        { "url": "https://api.adoptium.net/**" },
        { "url": "https://api.mojang.com/**" },
        { "url": "https://bin.equinox.io/**" },
        { "url": "https://tukuyomil032.github.io/**" }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$APPLOCALDATA/**" }, { "path": "$HOME/**" }]
    }
  ]
}
